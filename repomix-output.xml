<file path="tests/5-react-project/styles/App.css">
/* Основные стили приложения */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.app {
  min-height: 100vh;
  padding-bottom: 40px;
}

.container {
  max-width: 800px;
  margin: 0 auto;
  padding: 20px;
}

/* Статистика */
.stats {
  margin-bottom: 20px;
}

.stats h3 {
  color: #764ba2;
  margin-bottom: 16px;
  font-size: 20px;
}

.stats-text {
  font-size: 16px;
  color: #495057;
  margin-bottom: 8px;
  line-height: 1.6;
}

.stats-text strong {
  color: #667eea;
}

/* Форма добавления задачи */
.add-task-form {
  display: flex;
  gap: 12px;
  align-items: stretch;
}

.task-input {
  flex: 1;
  padding: 12px 16px;
  font-size: 16px;
  border: 2px solid #e9ecef;
  border-radius: 8px;
  outline: none;
  transition: border-color 0.3s;
}

.task-input:focus {
  border-color: #667eea;
}

/* Заголовок задач */
.tasks-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.tasks-header h3 {
  color: #764ba2;
  font-size: 20px;
}

.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  font-size: 14px;
  color: #6c757d;
}

.checkbox-label input[type="checkbox"] {
  cursor: pointer;
}

/* Список задач */
.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.task-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  background: #f8f9fa;
  border-radius: 8px;
  border: 2px solid #e9ecef;
  transition: all 0.3s;
}

.task-item:hover {
  border-color: #667eea;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
}

.task-item.completed {
  background: #e7f5ec;
  border-color: #28a745;
}

.task-checkbox {
  cursor: pointer;
  width: 20px;
  height: 20px;
}

.task-title {
  flex: 1;
  font-size: 16px;
  color: #495057;
}

.task-item.completed .task-title {
  text-decoration: line-through;
  color: #28a745;
}

.empty-message {
  text-align: center;
  color: #6c757d;
  padding: 40px 20px;
  font-size: 16px;
}

/* Информационный текст */
.info-text {
  font-size: 16px;
  color: #495057;
  line-height: 1.6;
  margin-bottom: 16px;
}

/* Список возможностей */
.features-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 16px;
}

.feature-item {
  font-size: 14px;
  color: #28a745;
  padding-left: 8px;
}

/* Адаптивность */
@media (max-width: 600px) {
  .container {
    padding: 12px;
  }

  .add-task-form {
    flex-direction: column;
  }

  .tasks-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
}
</file>

<file path="tests/5-react-project/styles/Button.css">
/* Стили для компонента Button */

.button {
  padding: 12px 24px;
