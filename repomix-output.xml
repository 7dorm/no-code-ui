 */
export function RenameDialog({ visible, onClose, onRename, itemName, itemPath }) {
  const [newName, setNewName] = useState('');

  useEffect(() => {
    if (visible) {
      setNewName(itemName || '');
    }
  }, [visible, itemName]);

  if (!visible) return null;

  const handleRename = () => {
    if (!newName.trim()) return;
